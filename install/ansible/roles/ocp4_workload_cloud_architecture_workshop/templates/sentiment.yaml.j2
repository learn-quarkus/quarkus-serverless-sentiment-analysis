{% for __user in r_cloud_architecture_workshop_users %}
---
apiVersion: argoproj.io/v1alpha1
kind: Application
metadata:
  name: {{ ocp4_workload_cloud_architecture_workshop_sentiment_analysis_name }}
  namespace: {{ ocp4_workload_cloud_architecture_workshop_argo_application_namespace | replace("user",__user) }}
  finalizers:
  - resources-finalizer.argocd.argoproj.io/foreground
spec:
  destination:
    name: ""
    namespace: {{ ocp4_workload_cloud_architecture_workshop_sentiment_analysis_name | replace("user",__user) }}
    server: 'https://kubernetes.default.svc'
  project: default
  syncPolicy:
    automated:
      prune: false
      selfHeal: false
  source:
    repoURL: https://github.com/rh-cloud-architecture-workshop/globex-sentiment-analysis-helm.git
    targetRevision: ocp18
    path: globex-sentiment-analysis/sentiment-analysis
    helm:
      values: |
        kafka:
          namespace: &namespace globex-mw-user1
          bootstrapServer: &bootstrapServer kafka-kafka-bootstrap.globex-mw-user1.svc.cluster.local:9092

        kafka-topics:
          kafka:
            namespace: *namespace
            cluster: kafka

        kafka-secret:
          kafka:
            namespace: *namespace

        knative-kafkasink:
          kafka:
            bootstrapServer: *bootstrapServer

        knative-kafkasource:
          kafka:
            bootstrapServer: *bootstrapServer

        product-reviews:
          kafkaSink:
            reviews: ${K_SINK}

        aiml-moderate-reviews:
          gunicorn:
            threads: "4"
            timeout: "180"

        aiml-sentiment-reviews:
          gunicorn:
            threads: "4"
            timeout: "180"

        globex-web-reviews:
          globexStoreApp:
            url: http://globex-store-app.globex-user1.svc.cluster.local:8080
          activityTrackingService:
            url: http://activity-tracking.globex-user1.svc.cluster.local:8080
            service: activity-tracking
            path: /track
          recommendationEngine:
            url: http://recommendation-engine.globex-user1.svc.cluster.local:8080
            service: recommendation-engine
            path: /score/product

          productReviews:
            url: http://product-reviews.globex-serverless.svc.cluster.local:8080
            submitReviewPath: /review/submit
            fetchReviewPath: /review/list

          sso:
            url: "https://sso.apps.mcp.ocp.sandbox2095.opentlc.com/realms/globex-user1"
            client: globex-web-gateway
            logoutUri: https://globex-web-globex-serverless.apps.mcp.ocp.sandbox2095.opentlc.com/home

{% endfor %}