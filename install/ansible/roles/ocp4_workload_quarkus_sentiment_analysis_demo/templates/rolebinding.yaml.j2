{% for __binding in ocp4_workload_quarkus_sentiment_analysis_bindings %}
---
apiVersion: rbac.authorization.k8s.io/v1
kind: RoleBinding
metadata:
  name: 'user{{ __binding.role }}-{{ __binding.namespace }}-namespace'
  namespace: '{{ __binding.namespace}}'
subjects:
- kind: User
  name: 'user'
  namespace: '{{ __binding.namespace }}'
roleRef:
  kind: ClusterRole
  name: '{{ __binding.role }}'
  apiGroup: rbac.authorization.k8s.io
{% endfor %}
