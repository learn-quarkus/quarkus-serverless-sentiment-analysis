---
apiVersion: argoproj.io/v1alpha1
kind: ApplicationSet
metadata:
  name: globex-gitops
  namespace: openshift-gitops
spec:
  generators:
  - list:
      elements:
{% for n in range(1, ocp4_workload_quarkus_sentiment_analysis_user_count | int + 1 ) %}
      - user: {{ ocp4_workload_quarkus_sentiment_analysis_user_prefix }}{{ n }}
{% endfor %}
  template:
    metadata:
      name: "{{ ocp4_workload_quarkus_sentiment_analysis_argo_application_name }}-{% raw %}{{ user }}{% endraw %}"
      namespace: openshift-gitops
      finalizers:
      - resources-finalizer.argocd.argoproj.io
    spec:
      destination:
        name: ""
        namespace: "globex-gitops"
        server: 'https://kubernetes.default.svc'
      project: default
      syncPolicy:
        automated:
          prune: false
          selfHeal: false
      source:
        repoURL: {{ ocp4_workload_quarkus_sentiment_analysis_application_repo }}
        targetRevision: {{ ocp4_workload_quarkus_sentiment_analysis_application_repo_tag }}
        path: {{ ocp4_workload_quarkus_sentiment_analysis_application_repo_path_gitops }}
        helm:
          values: |
            name: {{ ocp4_workload_quarkus_sentiment_analysis_argo_application_name }}-user{% endraw %}

            namespace: "{{ ocp4_workload_quarkus_sentiment_analysis_namespace_prefix }}-gitops-use{% endraw %}"
 
            applicationSet:
              resources:
                requests:
                  cpu: 100m
            controller:
              resources:
                requests:
                  cpu: 100m
            dex:
              resources:
                requests:
                  cpu: 100m
            repo:
              resources:
                requests:
                  cpu: 100m
            server:
              resources:
                requests:
                  cpu: 125m
