{% for __namespace in ocp4_workload_quarkus_sentiment_analysis_namespaces %}
---
apiVersion: v1
kind: Namespace
metadata:
  name: '{{ __namespace.name }}'
{% if __namespace.managedByArgo|length > 1 %}
  labels:
    argocd.argoproj.io/managed-by: {{ __namespace.managedByArgo }}
{% endif %}
{% endfor %}
